{
  "name": "union-mail-addin-installer",
  "version": "1.0.0",
  "description": "Standalone installer for 組合メール転送 Outlook add-in",
  "main": "index.js",
  "private": true,
  "scripts": {
    "build": "npx @yao-pkg/pkg index.js --config pkg.config.json --targets node18-win-x64 --output dist/install-addin.exe",
    "postbuild": "node copy-native.js"
  },
  "dependencies": {
    "@microsoft/teamsapp-cli": "3.0.2"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^5.12.0"
  }
}
