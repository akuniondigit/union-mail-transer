{
  "name": "union-mail-transer",
  "version": "0.1.0",
  "description": "Outlook add-in: 本部メールを区メンバーに半自動転送 (Office.js + TypeScript)",
  "private": true,
  "scripts": {
    "build": "webpack --mode production --env WEBPACK_BUILD=true",
    "build:dev": "webpack --mode development",
    "dev-server": "webpack serve --mode development",
    "watch": "webpack --mode development --watch",
    "validate": "office-addin-manifest validate manifest.xml",
    "start": "office-addin-debugging start manifest.xml",
    "stop": "office-addin-debugging stop manifest.xml",
    "sideload": "office-addin-manifest sideload outlook",
    "test": "vitest run"
  },
  "dependencies": {
    "core-js": "^3.36.0",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.377",
    "@types/office-runtime": "^1.0.35",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^7.1.4",
    "happy-dom": "^14.7.1",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-debugging": "^5.1.6",
    "office-addin-dev-certs": "^1.13.1",
    "office-addin-manifest": "^1.13.4",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
